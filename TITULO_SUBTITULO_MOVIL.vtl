		<script type="application/ld+json">
		{
		  "@context": "http://schema.org",
		  "@type": "NewsArticle",
		  "mainEntityOfPage": {
			"@type": "WebPage",
			"@id": "#organization"
		  },
		  "headline": "$TituloEsc",
		  #if($ogimage != "")
			"image": [
			"$ogimage"
		   ],
		  #end
		  "datePublished": "$formtLocal",
		  "dateModified": "$formtLocal",
		  "author": {
			"@type": "Person",
			"name": "$autorfinal"
		  },
		   "publisher": {
			"@type": "Organization",
			"name": "EDITORIAL VISTAZO",
			"logo": {
			  "@type": "ImageObject",
			  "url": "$logo"
			}
		  },
		  #if($fullaccess == "false")
			"isAccessibleForFree": "False",
			"hasPart":{
			"@type": "WebPageElement",
			"isAccessibleForFree": "False",
			"cssSelector" : ".restricted"
		  },
		  #end
		  "description": "$TextoEsc"
		}
		</script>
		<!-- ITEMS EN PAGINA  fullaccess: $fullaccess -->
		<meta itemscope itemprop="mainEntityOfPage" itemtype="https://schema.org/WebPage" itemid="#siteUrl()$url_actual" />
		<meta itemprop="datePublished" content="$dateF">
		<meta itemprop="dateModified" content="$dateF">
		<div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
			<meta itemprop="url" content="https://www.vistazo.com/" />
			<meta itemprop="name" content="Vistazo" />
			<div itemprop="logo" itemscope itemtype="https://schema.org/ImageObject">
				<meta itemprop="url" content="$iterVelocityTools.getVariable('0','logo')" />
				<meta itemprop="width" content="300" />
				<meta itemprop="height" content="43" />
			</div>
		</div>
#end