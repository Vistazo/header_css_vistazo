<div class="text_detail R_TEXT">
	<style>
		@keyframes diagonal-lines {
			0% {
				background-position: 0 0;
			}
			100% {
				background-position: 0px 0px; /* Mueve las líneas */
			}
		}

		.Center2Display {
			width: 100%;
			height: 250px;
			background: linear-gradient(to right, rgba(0, 0, 0, 0.05), rgba(150, 150, 150, 0.1)); /* Degradado */
			background-image: repeating-linear-gradient(
				45deg, /* Ángulo de las líneas */
				rgba(0, 0, 0, 0.05) 0px, 
				rgba(0, 0, 0, 0.05) 5px, 
				rgba(255, 255, 255, 0) 5px, 
				rgba(255, 255, 255, 0) 10px
			);
			background-size: 200% 200%; /* Ajuste del patrón */
			animation: diagonal-lines 8s linear infinite; /* Animación continua */
			display: flex;
			justify-content: center;
			align-items: center;
		}
	</style>
	<div class="text resizable" itemprop="articleBody">
		$fulltext
	</div>
    
