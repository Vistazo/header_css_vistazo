<script>

	var version = "4";
	var dateServer = "<?php echo date("d/m/Y H:i:s");?>";
	function timeAgo(date_str) {
		var date = getDate(date_str);
		var now  = getDate(dateServer);
		var ms = now.getTime() - date.getTime();
		var seconds = Math.floor(ms / 1000);
		var minutes = Math.floor(seconds / 60);
		var hours = Math.floor(minutes / 60);
		var days = Math.floor(hours / 24);
		var months = Math.floor(days / 30);
		var years = Math.floor(months / 12);
		if(ms < 0){
			return date_str;
		}
		if (ms === 0) {
			return "Hace un momento";
		}
		if (seconds < 60) {
			return "Hace " + seconds + " segundos";
		}
		if (minutes < 60) {
			return "Hace " + minutes + " minutos";
		}
		if (hours < 6) {
			return "Hace " + hours + " horas";
		}
		if (hours => 24) {
			return date_str;
		}
	}

	function getDate (date_str){
		let dateTimeString = date_str;
		const [dateString, timeString] = dateTimeString.split(' ');
		const [day, month, year] = dateString.split('/');
		const [hour, minute] = timeString.split(':');
		var d = new Date(+year, +month - 1, +day, +hour, +minute);
		return d;
	}


	function changeDatehora (){
		document.querySelectorAll('.r_date_post').forEach(el => {

			const text = el.textContent.trim();
			const [date, time] = text.split(" ");

			el.innerHTML = `
				<span class="time">${time}</span>
				<span class="date">${date}</span>
			`;

		});

	}

	setTimeout(() => {
		changeDatehora();
	}, 500);


